# Secrets
.env

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Runtime data (CSV persistence store, analytics extracts, caches, archives)
# The CSV "database" folder holds local plant data — never committed. Its README
# (data dictionary) IS tracked; the CSV/JSON data files are not. Use database/*
# (not database/) so the negation below can re-include the README.
database/*
!database/README.md
data/
*.csv

# Logs
logs/
*.log

# Playwright
.cache/
playwright-report/

# Node / vendored builds
node_modules/

# OS / editor
.DS_Store
.idea/
.vscode/

# Project: never track the ignore file
ignore.txt
