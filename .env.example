# =============================================================================
# Predictive Maintenance (PdM) System — environment TEMPLATE
# Copy to `.env` and fill in real values. Never commit the real `.env`.
# =============================================================================

# ----------------------------- Grafana ---------------------------------------
GRAFANA_BASE_URL=http://<grafana-host>/grafana
GRAFANA_USERNAME=<user>
GRAFANA_PASSWORD=<password>
GRAFANA_USERNAME_SELECTOR=input[name="user"]
GRAFANA_PASSWORD_SELECTOR=input[name="password"]
GRAFANA_SUBMIT_SELECTOR=button[type="submit"]
GRAFANA_DOWNLOAD_BUTTON_TEXT=Download CSV
PLAYWRIGHT_HEADLESS=true
GRAFANA_NAV_TIMEOUT_MS=30000

# ----------------------------- Database (MySQL) ------------------------------
# Dormant until STORAGE_BACKEND=mysql is explicitly enabled.
DB_HOST=<db-host>
DB_PORT=3306
DB_USER=<db-user>
DB_PASSWORD=<db-password>
DB_NAME=PDM
DB_CONNECTION_LIMIT=10

# ----------------------------- Storage backend -------------------------------
STORAGE_BACKEND=csv          # csv (default) | mysql (requires permission)
DATA_DIR=database            # CSV store root: database/store, /analytics, /archive, /exports
LOG_DIR=logs

# ----------------------------- Web application -------------------------------
APP_HOST=0.0.0.0
APP_PORT=8800
APP_TITLE=ASRS Predictive Maintenance

# ----------------------------- PdM defaults ----------------------------------
FETCH_DEFAULT_WINDOW=now-2d

# =============================================================================
# MODULE DASHBOARD URLS  (one block per module, filled after discovery)
# =============================================================================
# ----- LIFT module -----------------------------------------------------------
LIFT__LIFT_ERROR_HISTORY=
LIFT__QUADRON_CYCLES=
LIFT__LIFT_SUPPLY_TOTE=
LIFT__QUADRON_ERROR_HISTORY=
LIFT__BAD_TRACKER_DIAGNOSIS=
